[0.314, "o", "def add(a, b):\r\n    return a - b  # BUG: should be a + b\r\n\r\ndef multiply(a, b):\r\n    return a * b\r\n\r\ndef divide(a, b):\r\n    return a / b  # BUG: no zero division check\r\n\r\ndef greet(name):\r\n    print(f\"Hello, {nme}!\")  # BUG: typo in variable name\r\n\r\nif __name__ == \"__main__\":\r\n    print(f\"2 + 3 = {add(2, 3)}\")\r\n    print(f\"10 / 0 = {divide(10, 0)}\")\r\n    greet(\"World\")\r\n"]
