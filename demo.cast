[0.517, "o", "my-little-claude -- a model-agnostic coding agent\r\n\r\n\u001b[1m\u001b[4mUsage:\u001b[0m \u001b[1munripe\u001b[0m [OPTIONS] [PROMPT] [COMMAND]\r\n\r\n\u001b[1m\u001b[4mCommands:\u001b[0m\r\n  \u001b[1mreplay\u001b[0m    Replay a saved session with a different model\r\n  \u001b[1msessions\u001b[0m  List saved sessions\r\n  \u001b[1msetup\u001b[0m     Detect hardware and set up a local model\r\n  \u001b[1mhelp\u001b[0m      Print this message or the help of the given subcommand(s)\r\n\r\n\u001b[1m\u001b[4mArguments:\u001b[0m\r\n  [PROMPT]  The prompt to send to the agent (shorthand for `unripe run \"prompt\"`)\r\n\r\n\u001b[1m\u001b[4mOptions:\u001b[0m\r\n      \u001b[1m--provider\u001b[0m <PROVIDER>  LLM provider to use (anthropic, ollama)\r\n      \u001b[1m--model\u001b[0m <MODEL>        Model name to use\r\n      \u001b[1m--resume\u001b[0m               Resume the most recent session\r\n      \u001b[1m--chat\u001b[0m                 Chat-only mode (no tool calling, just conversation)\r\n  \u001b[1m-h\u001b[0m, \u001b[1m--help\u001b[0m                 Print help\r\n  \u001b[1m-V\u001b[0m, \u001b[1m--version\u001b[0m              Print version\r\n"]
